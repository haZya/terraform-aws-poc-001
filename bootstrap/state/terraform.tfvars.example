region         = "ap-southeast-2"
profile        = "bootstrap-account"
aws_account_id = "000000000000"
app_name       = "poc-001"

# Optional. If omitted, bootstrap uses "${app_name}-terraform-state-${current_account_id}".
# state_bucket_name = "poc-001-terraform-state-000000000000"

# Add deployment role ARNs from bootstrap/accounts/* before the first state apply.
# Add any local dev role/user principals that need cross-account state bucket access.
